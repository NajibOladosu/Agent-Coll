# Shared .env for all agents. Live file is .env (gitignored).
# Each agent reads what it needs from here.

# ---- Quill (LinkedIn poster) ----
LINKEDIN_TOKEN=
GEMINI_API_KEY=
# GITHUB_TOKEN optional — only needed locally to bypass GH API rate limits
GITHUB_TOKEN=

# ---- Reddit Advocate ----
# Create app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=python:reddit_advocate:v0.1 (by /u/yourname)
REDDIT_DAILY_CAP=5
REDDIT_KILL=0
